<?php
// private/config.php.example
// このファイルをコピーして private/config.php を作成し、値を設定すること。
// config.php 自体はGit管理対象外(.gitignore)。必要最低限の項目のみを保持する。

return [
    // --- SMTP ---
    'smtp_host' => '',                  // 例: sv***.xserver.jp(XServerのサーバーパネルで確認)
    'smtp_port' => 587,                 // 587=STARTTLS を推奨。465を使う場合は smtp_encryption を 'ssl' に
    'smtp_encryption' => 'tls',         // 'tls'(STARTTLS、587番想定) または 'ssl'(暗黙のTLS、465番想定)
    'smtp_user' => '',                  // 例: info@smartlaboworks.com(認証アカウント。送信元アドレスとしても使用)
    'smtp_pass' => '',

    // --- 管理者メール(問い合わせ通知の宛先) ---
    'admin_email' => '',                // 例: info@smartlaboworks.com

    // --- CSRF署名鍵 ---
    'csrf_secret' => '',                // 生成例: php -r "echo bin2hex(random_bytes(32));"

    // --- reCAPTCHA(v3 / Enterprise) ---
    // ホームページ正式公開直前まで recaptcha_enabled は false のまま運用する(開発モード)。
    // true に切り替えるとreCAPTCHA検証が必須になる(本番モード)。
    // Enterpriseへ切り替える場合は public/lib/recaptcha.php の検証先を差し替えるだけでよい。
    'recaptcha_enabled' => false,
    'recaptcha_secret' => '',
];
