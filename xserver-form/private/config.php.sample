//
// このファイルにはSMTP情報・各種キー・秘密情報のみを保持する(2026-07-14 CEO指示)。
// CORS許可オリジンの一覧など秘密情報でない設定値は lib/settings.php(Git管理対象)側で管理する。

return [
    // SMTP認証情報(秘密情報)。認証アカウントは contact@smartlaboworks.com を推奨。
    'smtp_host' => '',
    'smtp_port' => 587,
    'smtp_user' => '',   // 例: contact@smartlaboworks.com
    'smtp_pass' => '',

    // メールアドレス構成(推奨構成。2026-07-14 CEO承認)
    // info@smartlaboworks.com は代表メールであり、送信処理では使用しない。
    'admin_notify_to' => '',       // 管理者通知の宛先。例: contact@smartlaboworks.com
    'mail_from' => '',             // 管理者通知の送信元。例: contact@smartlaboworks.com
    'mail_from_name' => 'Smart Labo Works',
    'auto_reply_from' => '',       // 自動返信の送信元。当面は contact@smartlaboworks.com。
                                    // 将来 noreply@smartlaboworks.com を作成した場合、
                                    // この値のみ変更すれば切替できる(コード変更不要)。
    'auto_reply_from_name' => 'Smart Labo Works',

    // CSRF署名鍵(秘密情報)。生成例: php -r "echo bin2hex(random_bytes(32));"
    'csrf_secret' => '',

    // reCAPTCHA v3(秘密情報)。ホームページ正式公開直前まで recaptcha_enabled は false のまま運用する。
    'recaptcha_enabled' => false,
    'recaptcha_secret' => '',
];
