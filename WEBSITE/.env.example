# Smart Labo Works ホームページ 問い合わせフォーム — 環境変数サンプル
# 実際の値は .env(Gitにコミットしない)またはVercelの環境変数設定で管理する。

# CSRF署名用シークレット(ランダムな長い文字列。例: openssl rand -hex 32)
CONTACT_CSRF_SECRET=

# 許可オリジン(カンマ区切り。本番の正式ドメイン確定後に追記)
CONTACT_ALLOWED_ORIGINS=https://smartlabosukimagakusyuu-dev.github.io

# 管理者への通知先メールアドレス(CEO確認待ち)
CONTACT_NOTIFY_TO=

# 送信元メールアドレス(CEO確認待ち。SMTPアカウントと一致させること)
CONTACT_FROM_EMAIL=

# SMTP接続情報(CEO確認待ち。利用するメール配信サービスにより異なる)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Google reCAPTCHA v3 シークレットキー(CEOによる管理画面登録が必要)
RECAPTCHA_SECRET_KEY=
